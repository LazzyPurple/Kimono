generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  totpSecret  String?
  totpEnabled Boolean   @default(false)
  passkeys    Passkey[]
  sessions    Session[]
  createdAt   DateTime  @default(now())
}

model Passkey {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique
  publicKey    String
  counter      BigInt
  deviceName   String?
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model KimonoSession {
  id       String   @id @default(cuid())
  site     String   @unique
  cookie   String
  username String
  savedAt  DateTime @default(now())

  @@index([savedAt], map: "KimonoSession_savedAt_idx")
}

model Creator {
  site            String
  service         String
  creatorId       String
  name            String
  normalizedName  String
  indexed         BigInt?
  updated         BigInt?
  favorited       Int       @default(0)
  postCount       Int       @default(0)
  publicId        String?
  relationId      BigInt?
  dmCount         Int       @default(0)
  shareCount      Int       @default(0)
  hasChats        Boolean   @default(false)
  chatCount       Int       @default(0)
  profileImageUrl String?
  bannerImageUrl  String?
  rawIndexPayload String?
  rawProfilePayload String?
  catalogSyncedAt DateTime  @default(now())
  profileCachedAt DateTime?
  profileExpiresAt DateTime?
  archivedAt      DateTime?

  @@id([site, service, creatorId])
  @@index([normalizedName], map: "Creator_normalizedName_idx")
  @@index([site, service, favorited], map: "Creator_site_service_favorited_idx")
  @@index([site, service, updated], map: "Creator_site_service_updated_idx")
  @@index([catalogSyncedAt], map: "Creator_catalogSyncedAt_idx")
  @@index([profileExpiresAt], map: "Creator_profileExpiresAt_idx")
}

model Post {
  site                        String
  service                     String
  creatorId                   String
  postId                      String
  title                       String?
  contentHtml                 String?
  excerpt                     String?
  publishedAt                 DateTime?
  addedAt                     DateTime?
  editedAt                    DateTime?
  fileName                    String?
  filePath                    String?
  attachmentsJson             String?
  embedJson                   String?
  tagsJson                    String?
  prevPostId                  String?
  nextPostId                  String?
  favCount                    Int       @default(0)
  previewImageUrl             String?
  videoUrl                    String?
  thumbUrl                    String?
  mediaType                   String?
  authorName                  String?
  rawPreviewPayload           String?
  rawDetailPayload            String?
  detailLevel                 String    @default("preview")
  sourceKind                  String    @default("upstream")
  isPopular                   Boolean   @default(false)
  primaryPopularPeriod        String?
  primaryPopularDate          String?
  primaryPopularOffset        Int?
  primaryPopularRank          Int?
  popularContextsJson         String?
  longestVideoUrl             String?
  longestVideoDurationSeconds Float?
  previewStatus               String?
  nativeThumbnailUrl          String?
  previewThumbnailAssetPath   String?
  previewClipAssetPath        String?
  previewGeneratedAt          DateTime?
  previewError                String?
  previewSourceFingerprint    String?
  mediaMimeType               String?
  mediaWidth                  Int?
  mediaHeight                 Int?
  cachedAt                    DateTime  @default(now())
  expiresAt                   DateTime
  staleUntil                  DateTime?
  lastSeenAt                  DateTime?

  @@id([site, service, creatorId, postId])
  @@index([site, service, creatorId, publishedAt], map: "Post_creator_published_idx")
  @@index([expiresAt], map: "Post_expiresAt_idx")
  @@index([site, previewSourceFingerprint], map: "Post_previewSourceFingerprint_idx")
  @@index([site, isPopular, primaryPopularPeriod, primaryPopularDate, primaryPopularOffset, primaryPopularRank], map: "Post_popular_lookup_idx")
  @@index([lastSeenAt], map: "Post_lastSeenAt_idx")
}

model FavoriteChronology {
  kind            String
  site            String
  service         String
  creatorId       String
  postId          String   @default("")
  favoritedAt     DateTime @default(now())
  lastConfirmedAt DateTime @default(now())

  @@id([kind, site, service, creatorId, postId])
  @@index([lastConfirmedAt], map: "FavoriteChronology_lastConfirmedAt_idx")
  @@index([kind, site, favoritedAt], map: "FavoriteChronology_kind_site_favoritedAt_idx")
  @@index([favedSeq], map: "FavoriteChronology_favedSeq_idx")
}

model FavoriteCache {
  kind       String
  site       String
  payloadJson String
  updatedAt  DateTime @default(now())
  expiresAt  DateTime

  @@id([kind, site])
  @@index([expiresAt], map: "FavoriteCache_expiresAt_idx")
}

model MediaAsset {
  site                String
  sourceFingerprint   String
  sourceUrl           String
  sourcePath          String?
  mediaKind           String?
  mimeType            String?
  width               Int?
  height              Int?
  durationSeconds     Float?
  nativeThumbnailUrl  String?
  thumbnailAssetPath  String?
  clipAssetPath       String?
  probeStatus         String   @default("pending")
  previewStatus       String   @default("pending")
  firstSeenAt         DateTime @default(now())
  lastSeenAt          DateTime @default(now())
  hotUntil            DateTime?
  retryAfter          DateTime?
  generationAttempts  Int      @default(0)
  lastError           String?
  lastObservedContext String?
  cachedAt            DateTime @default(now())
  expiresAt           DateTime?

  @@id([site, sourceFingerprint])
  @@index([lastSeenAt], map: "MediaAsset_lastSeenAt_idx")
  @@index([hotUntil], map: "MediaAsset_hotUntil_idx")
  @@index([retryAfter], map: "MediaAsset_retryAfter_idx")
  @@index([expiresAt], map: "MediaAsset_expiresAt_idx")
}

model MediaSource {
  site                String
  sourceFingerprint   String
  sourceUrl           String
  sourcePath          String?
  localPath           String?
  downloadStatus      String   @default("pending")
  downloadedAt        DateTime?
  lastSeenAt          DateTime @default(now())
  retentionUntil      DateTime?
  fileSizeBytes       BigInt?
  mimeType            String?
  downloadError       String?
  downloadAttempts    Int      @default(0)
  lastObservedContext String?
  priorityClass       String?
  retryAfter          DateTime?
  firstSeenAt         DateTime @default(now())

  @@id([site, sourceFingerprint])
  @@index([lastSeenAt], map: "MediaSource_lastSeenAt_idx")
  @@index([retentionUntil], map: "MediaSource_retentionUntil_idx")
  @@index([priorityClass], map: "MediaSource_priorityClass_idx")
  @@index([retryAfter], map: "MediaSource_retryAfter_idx")
}

model DiscoveryCache {
  site       String   @id
  payloadJson String
  updatedAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt], map: "DiscoveryCache_expiresAt_idx")
}

model DiscoveryBlock {
  site      String
  service   String
  creatorId String
  blockedAt DateTime @default(now())

  @@id([site, service, creatorId])
  @@index([blockedAt], map: "DiscoveryBlock_blockedAt_idx")
}

